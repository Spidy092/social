<div class="max-w-5xl mx-auto">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Platform Connections</h1>
      <p class="text-gray-500 mt-1">Connect your social media accounts to start posting</p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

    <%
      const platformConfig = {
        instagram: {
          name: 'Instagram',
          color: 'from-pink-500 to-purple-600',
          bgLight: 'bg-gradient-to-br from-pink-50 to-purple-50',
          borderColor: 'border-pink-200',
          icon: '📸',
          connectNote: 'Connects via Meta (also connects Facebook)',
          connectUrl: '/platforms/meta/connect'
        },
        facebook: {
          name: 'Facebook',
          color: 'from-blue-600 to-blue-700',
          bgLight: 'bg-gradient-to-br from-blue-50 to-indigo-50',
          borderColor: 'border-blue-200',
          icon: '📘',
          connectNote: 'Connects via Meta (also connects Instagram)',
          connectUrl: '/platforms/meta/connect'
        },
        linkedin: {
          name: 'LinkedIn',
          color: 'from-sky-600 to-sky-700',
          bgLight: 'bg-gradient-to-br from-sky-50 to-cyan-50',
          borderColor: 'border-sky-200',
          icon: '💼',
          connectNote: 'Share posts to your LinkedIn profile',
          connectUrl: '/platforms/linkedin/connect'
        },
        youtube: {
          name: 'YouTube',
          color: 'from-red-500 to-red-600',
          bgLight: 'bg-gradient-to-br from-red-50 to-orange-50',
          borderColor: 'border-red-200',
          icon: '🎬',
          connectNote: 'Upload videos to your YouTube channel',
          connectUrl: '/platforms/youtube/connect'
        }
      };

      const platforms = ['instagram', 'facebook', 'linkedin', 'youtube'];
    %>

    <% platforms.forEach(platform => {
      const config = platformConfig[platform];
      const conn = connections[platform];
    %>
      <div class="rounded-xl border <%= conn ? config.borderColor : 'border-gray-200' %> <%= conn ? config.bgLight : 'bg-white' %> shadow-sm hover:shadow-md transition-shadow overflow-hidden">
        <!-- Header with gradient -->
        <div class="bg-gradient-to-r <%= config.color %> px-6 py-4">
          <div class="flex items-center justify-between">
            <div class="flex items-center space-x-3">
              <span class="text-2xl"><%= config.icon %></span>
              <h3 class="text-lg font-semibold text-white"><%= config.name %></h3>
            </div>
            <% if (conn) { %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-white/20 text-white backdrop-blur-sm">
                ✓ Connected
              </span>
            <% } else { %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-white/10 text-white/70 backdrop-blur-sm">
                Not Connected
              </span>
            <% } %>
          </div>
        </div>

        <!-- Body -->
        <div class="px-6 py-5">
          <% if (conn) { %>
            <div class="space-y-3">
              <div class="flex items-center space-x-2">
                <span class="w-2 h-2 bg-green-400 rounded-full"></span>
                <span class="text-sm text-gray-600">Connected as</span>
              </div>
              <p class="text-base font-semibold text-gray-900"><%= conn.platform_username || 'Unknown' %></p>
              <% if (conn.token_expires_at) { %>
                <p class="text-xs text-gray-400">
                  Token expires: <%= new Date(conn.token_expires_at).toLocaleDateString() %>
                </p>
              <% } %>

              <form action="/platforms/<%= platform %>/disconnect?_method=DELETE" method="POST" class="pt-2"
                    onsubmit="return confirm('Disconnect <%= config.name %>?')">
                <input type="hidden" name="_method" value="DELETE">
                <button type="submit"
                        class="w-full px-4 py-2 text-sm font-medium text-red-600 bg-red-50 rounded-lg hover:bg-red-100 border border-red-200 transition-colors">
                  Disconnect
                </button>
              </form>
            </div>
          <% } else { %>
            <div class="space-y-4">
              <p class="text-sm text-gray-500"><%= config.connectNote %></p>
              <a href="<%= config.connectUrl %>"
                 class="block w-full text-center px-4 py-2.5 text-sm font-medium text-white bg-gradient-to-r <%= config.color %> rounded-lg hover:opacity-90 transition-opacity shadow-sm">
                Connect <%= config.name %>
              </a>
            </div>
          <% } %>
        </div>
      </div>
    <% }); %>

  </div>

  <!-- Info notice -->
  <div class="mt-8 rounded-lg bg-amber-50 border border-amber-200 p-4">
    <div class="flex">
      <span class="text-amber-500 mr-3">⚠️</span>
      <div class="text-sm text-amber-700">
        <p class="font-medium">Note about Meta platforms</p>
        <p class="mt-1">Instagram and Facebook share the same OAuth flow. Connecting one will automatically connect the other if your Facebook Page has a linked Instagram Business Account.</p>
      </div>
    </div>
  </div>
</div>
