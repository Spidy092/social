<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Social Poster</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/app.css">
  <meta name="csrf-token" content="<%= csrfToken %>">
</head>
<body class="bg-gray-50 text-gray-900 font-sans">
  <div class="flex h-screen overflow-hidden relative">
    
    <!-- Sidebar Mobile Backdrop -->
    <div id="sidebar-backdrop" class="fixed inset-0 bg-slate-900/50 backdrop-blur-sm z-30 hidden md:hidden transition-opacity duration-300 opacity-0"></div>

    <!-- Sidebar -->
    <aside id="sidebar" class="fixed md:static inset-y-0 left-0 z-40 w-64 bg-slate-900 text-white flex-shrink-0 flex flex-col h-full transform -translate-x-full md:translate-x-0 transition-transform duration-300 ease-in-out shadow-2xl md:shadow-none">
      <div class="p-6 flex items-center justify-between border-b border-slate-800 md:border-b-0">
        <h1 class="text-xl font-bold tracking-tight">SocialPoster</h1>
        <!-- Sidebar Close Button (Mobile Only) -->
        <button id="sidebar-close" class="p-2 -mr-2 text-slate-400 hover:text-white md:hidden rounded-lg focus:outline-none focus:ring-2 focus:ring-slate-500" aria-label="Close Menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
      <nav class="flex-1 px-4 space-y-1 mt-4 overflow-y-auto">
        <a href="/" class="flex items-center px-4 py-3 text-sm rounded-lg <%= activePage === 'dashboard' ? 'bg-slate-800 text-white' : 'text-slate-400 hover:bg-slate-800 hover:text-white transition' %>">
          <span>Dashboard</span>
        </a>
        <a href="/upload" class="flex items-center px-4 py-3 text-sm rounded-lg <%= activePage === 'upload' ? 'bg-slate-800 text-white' : 'text-slate-400 hover:bg-slate-800 hover:text-white transition' %>">
          <span>Upload</span>
        </a>
        <a href="/schedule" class="flex items-center px-4 py-3 text-sm rounded-lg <%= activePage === 'schedule' ? 'bg-slate-800 text-white' : 'text-slate-400 hover:bg-slate-800 hover:text-white transition' %>">
          <span>Schedule</span>
        </a>
        <a href="/platforms" class="flex items-center px-4 py-3 text-sm rounded-lg <%= activePage === 'platforms' ? 'bg-slate-800 text-white' : 'text-slate-400 hover:bg-slate-800 hover:text-white transition' %>">
          <span>Platforms</span>
        </a>
        <a href="/media" class="flex items-center px-4 py-3 text-sm rounded-lg <%= activePage === 'media' ? 'bg-slate-800 text-white' : 'text-slate-400 hover:bg-slate-800 hover:text-white transition' %>">
          <span>Media Library</span>
        </a>
        <a href="/analytics" class="flex items-center px-4 py-3 text-sm rounded-lg <%= activePage === 'analytics' ? 'bg-slate-800 text-white' : 'text-slate-400 hover:bg-slate-800 hover:text-white transition' %>">
          <span>Analytics</span>
        </a>
        <% if (user && user.role === 'admin') { %>
        <a href="/admin/users" class="flex items-center px-4 py-3 text-sm rounded-lg <%= activePage === 'admin' ? 'bg-slate-800 text-white' : 'text-slate-400 hover:bg-slate-800 hover:text-white transition' %>">
          <span>Users</span>
        </a>
        <% } %>
      </nav>
      <div class="p-4 border-t border-slate-800">
        <a href="/logout" class="flex items-center px-4 py-2 text-sm text-slate-400 hover:text-white">
          <span>Logout</span>
        </a>
      </div>
    </aside>

    <!-- Main content -->
    <main class="flex-1 overflow-y-auto relative flex flex-col min-w-0">
      <header class="h-16 border-b bg-white flex items-center justify-between px-4 md:px-8 sticky top-0 z-10 flex-shrink-0">
        <div class="flex items-center space-x-3 min-w-0">
          <!-- Sidebar Hamburger Trigger (Mobile Only) -->
          <button id="sidebar-toggle" class="p-2 -ml-2 text-slate-600 hover:text-slate-900 md:hidden rounded-lg hover:bg-slate-100 focus:outline-none focus:ring-2 focus:ring-slate-500" aria-label="Toggle Menu">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
          </button>
          <h2 class="text-lg font-semibold capitalize truncate"><%= activePage %></h2>
        </div>
        <div class="flex items-center space-x-4 flex-shrink-0">
          <span class="text-sm text-gray-500 truncate max-w-[150px] sm:max-w-none"><%= user ? user.email : 'Admin' %></span>
        </div>
      </header>

      <div class="p-4 sm:p-8 flex-1">
        <%- include('../partials/flash') %>
        <%- body %>
      </div>
    </main>
  </div>

  <!-- Sidebar Responsive Toggler Script -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const sidebar = document.getElementById('sidebar');
      const backdrop = document.getElementById('sidebar-backdrop');
      const toggleBtn = document.getElementById('sidebar-toggle');
      const closeBtn = document.getElementById('sidebar-close');

      function openSidebar() {
        sidebar.classList.remove('-translate-x-full');
        backdrop.classList.remove('hidden');
        // Trigger transition
        setTimeout(() => {
          backdrop.classList.remove('opacity-0');
          backdrop.classList.add('opacity-100');
        }, 10);
      }

      function closeSidebar() {
        sidebar.classList.add('-translate-x-full');
        backdrop.classList.remove('opacity-100');
        backdrop.classList.add('opacity-0');
        // Hide after transition
        setTimeout(() => {
          backdrop.classList.add('hidden');
        }, 300);
      }

      if (toggleBtn) toggleBtn.addEventListener('click', openSidebar);
      if (closeBtn) closeBtn.addEventListener('click', closeSidebar);
      if (backdrop) backdrop.addEventListener('click', closeSidebar);
    });
  </script>

  <script src="/js/app.js"></script>
</body>
</html>
