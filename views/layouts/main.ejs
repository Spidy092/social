<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Social Poster</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/app.css">
</head>
<body class="bg-gray-50 text-gray-900 font-sans">
  <div class="flex h-screen overflow-hidden">
    <!-- Sidebar -->
    <aside class="w-64 bg-slate-900 text-white flex-shrink-0 flex flex-col h-full">
      <div class="p-6">
        <h1 class="text-xl font-bold tracking-tight">SocialPoster</h1>
      </div>
      <nav class="flex-1 px-4 space-y-1 mt-4">
        <a href="/" class="flex items-center px-4 py-3 text-sm rounded-lg <%= activePage === 'dashboard' ? 'bg-slate-800 text-white' : 'text-slate-400 hover:bg-slate-800 hover:text-white transition' %>">
          <span>Dashboard</span>
        </a>
        <a href="/upload" class="flex items-center px-4 py-3 text-sm rounded-lg <%= activePage === 'upload' ? 'bg-slate-800 text-white' : 'text-slate-400 hover:bg-slate-800 hover:text-white transition' %>">
          <span>Upload</span>
        </a>
        <a href="/schedule" class="flex items-center px-4 py-3 text-sm rounded-lg <%= activePage === 'schedule' ? 'bg-slate-800 text-white' : 'text-slate-400 hover:bg-slate-800 hover:text-white transition' %>">
          <span>Schedule</span>
        </a>
        <a href="/platforms" class="flex items-center px-4 py-3 text-sm rounded-lg <%= activePage === 'platforms' ? 'bg-slate-800 text-white' : 'text-slate-400 hover:bg-slate-800 hover:text-white transition' %>">
          <span>Platforms</span>
        </a>
        <a href="/analytics" class="flex items-center px-4 py-3 text-sm rounded-lg <%= activePage === 'analytics' ? 'bg-slate-800 text-white' : 'text-slate-400 hover:bg-slate-800 hover:text-white transition' %>">
          <span>Analytics</span>
        </a>
      </nav>
      <div class="p-4 border-t border-slate-800">
        <a href="/logout" class="flex items-center px-4 py-2 text-sm text-slate-400 hover:text-white">
          <span>Logout</span>
        </a>
      </div>
    </aside>

    <!-- Main content -->
    <main class="flex-1 overflow-y-auto relative">
      <header class="h-16 border-b bg-white flex items-center justify-between px-8 sticky top-0 z-10">
        <h2 class="text-lg font-semibold capitalize"><%= activePage %></h2>
        <div class="flex items-center space-x-4">
          <span class="text-sm text-gray-500"><%= user ? user.email : 'Admin' %></span>
        </div>
      </header>

      <div class="p-8">
        <%- include('../partials/flash') %>
        <%- body %>
      </div>
    </main>
  </div>
  <script src="/js/app.js"></script>
</body>
</html>
