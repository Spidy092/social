<div class="max-w-6xl mx-auto">
  <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
    <table class="w-full text-left border-collapse">
      <thead>
        <tr class="border-b border-slate-50">
          <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Media</th>
          <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Content Preview</th>
          <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest">Platforms</th>
          <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest text-center">Status</th>
          <th class="px-6 py-4 text-xs font-bold text-slate-400 uppercase tracking-widest text-right">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-50">
        <% if (posts.length === 0) { %>
            <tr>
                <td colspan="5" class="px-6 py-20 text-center text-slate-400">
                    <p class="text-sm font-medium">No posts found.</p>
                    <a href="/upload" class="text-slate-900 font-bold underline mt-2 inline-block">Upload your first post</a>
                </td>
            </tr>
        <% } %>
        <% posts.forEach(post => { %>
          <tr class="hover:bg-slate-50/50 transition">
            <td class="px-6 py-4">
              <div class="h-16 w-16 rounded-xl overflow-hidden bg-slate-100 border border-slate-200 flex items-center justify-center">
                <% if (post.media_type === 'image') { %>
                  <img src="<%= post.media_url %>" class="h-full w-full object-cover">
                <% } else { %>
                  <div class="p-2 text-slate-400">
                    <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24"><path d="M10 15l5.197-3L10 9v6z"/><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/></svg>
                  </div>
                <% } %>
              </div>
            </td>
            <td class="px-6 py-4">
              <p class="text-sm font-medium text-slate-900 truncate max-w-xs"><%= post.caption_original || 'No caption' %></p>
              <p class="text-xs text-slate-400 mt-1">
                <% if (post.scheduled_at) { %>
                    <span class="flex items-center">
                        <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                        <%= new Date(post.scheduled_at).toLocaleString() %>
                    </span>
                <% } else { %>
                    Post Instantly
                <% } %>
              </p>
            </td>
            <td class="px-6 py-4">
              <div class="flex flex-wrap gap-2">
                <% Object.keys(post.platforms).forEach(p => { %>
                  <span class="px-2 py-0.5 bg-slate-100 text-[10px] font-bold text-slate-600 rounded-md capitalize"><%= p %></span>
                <% }) %>
              </div>
            </td>
            <td class="px-6 py-4 text-center">
              <% 
                const statusColors = {
                    'draft': 'bg-gray-100 text-gray-700',
                    'pending': 'bg-amber-100 text-amber-700',
                    'publishing': 'bg-blue-100 text-blue-700',
                    'published': 'bg-green-100 text-green-700',
                    'failed': 'bg-red-100 text-red-700'
                }
              %>
              <span class="inline-flex px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-wider <%= statusColors[post.status] || 'bg-gray-100' %>">
                <%= post.status %>
              </span>
            </td>
            <td class="px-6 py-4 text-right">
              <div class="flex items-center justify-end space-x-2">
                <form action="/posts/<%= post.id %>/publish-now" method="POST">
                    <button type="submit" class="p-2 text-slate-400 hover:text-slate-900 transition" title="Publish Now">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7"></path></svg>
                    </button>
                </form>
                <form action="/posts/<%= post.id %>/delete" method="POST" onsubmit="return confirm('Really delete this post?')">
                    <button type="submit" class="p-2 text-slate-400 hover:text-red-600 transition" title="Delete">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                    </button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
