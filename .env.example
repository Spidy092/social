# App
PORT=3000
APP_URL=http://localhost:3000
NODE_ENV=development

# Database
DATABASE_URL=

# Session
SESSION_SECRET=

# Admin user (used by seed script — run once after deploy)
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Cloudinary — cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# OpenRouter / Anthropic — for AI captions
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=

# Meta (Instagram + Facebook) — developers.facebook.com/apps
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=https://YOUR_RAILWAY_URL/platforms/meta/callback

# LinkedIn — developer.linkedin.com
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=https://YOUR_RAILWAY_URL/platforms/linkedin/callback

# YouTube / Google — console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://YOUR_RAILWAY_URL/platforms/youtube/callback
